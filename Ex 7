#include <stdio.h>

int main() {
    int n, i, j;
    int bt[10], wt[10], tat[10], p[10];
    int temp;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    // Input burst times
    for(i = 0; i < n; i++) {
        p[i] = i + 1;   // Process number
        printf("Enter Burst Time for P%d: ", p[i]);
        scanf("%d", &bt[i]);
    }

    // Sort according to burst time (SJF)
    for(i = 0; i < n - 1; i++) {
        for(j = i + 1; j < n; j++) {
            if(bt[i] > bt[j]) {
                temp = bt[i];
                bt[i] = bt[j];
                bt[j] = temp;

                temp = p[i];
                p[i] = p[j];
                p[j] = temp;
            }
        }
    }

    // Calculate waiting time
    wt[0] = 0;
    for(i = 1; i < n; i++)
        wt[i] = wt[i - 1] + bt[i - 1];

    // Calculate turnaround time
    for(i = 0; i < n; i++)
        tat[i] = wt[i] + bt[i];

    // Display results
    printf("\nProcess\tBT\tWT\tTAT\n");
    for(i = 0; i < n; i++)
        printf("P%d\t%d\t%d\t%d\n", p[i], bt[i], wt[i], tat[i]);

    return 0;
}
