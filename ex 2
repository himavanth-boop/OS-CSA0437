#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main() {
    int src, dest;
    char buffer[100];
    int bytes;

    src = open("source.txt", O_RDONLY);
    dest = open("dest.txt", O_WRONLY | O_CREAT | O_TRUNC, 0644);

    while ((bytes = read(src, buffer, sizeof(buffer))) > 0)
        write(dest, buffer, bytes);

    close(src);
    close(dest);

    printf("File Copied Successfully\n");
    return 0;
}
