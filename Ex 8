#include <stdio.h>

int main(){
    int n, bt[10], rt[10], tq, done;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(int i=0;i<n;i++){
        scanf("%d",&bt[i]);
        rt[i]=bt[i];
    }

    printf("Enter time quantum: ");
    scanf("%d",&tq);

    do{
        done=1;
        for(int i=0;i<n;i++){
            if(rt[i]>0){
                done=0;
                if(rt[i]>tq)
                    rt[i]-=tq;
                else
                    rt[i]=0;
            }
        }
    }while(!done);

    printf("Round Robin Completed\n");
    return 0;
}
